# Скопировать в .env и заполнить. В CI задаётся через GitHub Secrets.

# Провайдер сентимента: gemini (по умолчанию, дёшево) | anthropic | none
SENTIMENT_PROVIDER=gemini

# Gemini (Google AI Studio, есть бесплатный tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic — нужен только для отчёта (генерация текста) и провайдера anthropic
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
